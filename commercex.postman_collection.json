    {
      "name": "Orders",
      "description": "Order placement and management. Create order uses the active cart.",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('order_id', jsonData.id);",
                  "    console.log('Order ID saved: ' + jsonData.id + ', Status: ' + jsonData.status);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
