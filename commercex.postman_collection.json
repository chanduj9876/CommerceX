    {
      "name": "Cart",
      "description": "Shopping cart management. All endpoints require authentication.",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/cart",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart"]
            }
          },
          "response": []
        },
        {
          "name": "Add Item to Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.items && jsonData.items.length > 0) {",
                  "        pm.collectionVariables.set('cart_item_id', jsonData.items[0].id);",
                  "        console.log('Cart item ID saved: ' + jsonData.items[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{product_id}},\n  \"quantity\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/cart/items",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", "items"]
            }
          },
          "response": []
        },
        {
          "name": "Update Item Quantity",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/v1/cart/items/{{cart_item_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", "items", "{{cart_item_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/v1/cart/items/{{cart_item_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cart", "items", "{{cart_item_id}}"]
            }
          },
          "response": []
        },
