              "host": ["{{base_url}}"],
              "path": ["api", "v1", "orders"],
              "query": [
                { "key": "status", "value": "PENDING", "description": "Filter by status: PENDING, CONFIRMED, SHIPPED, DELIVERED, CANCELLED" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
